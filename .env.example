# Copy this file to .env and fill in real values for production
# In development, these defaults are safe to leave as-is

DJANGO_SECRET_KEY=nextreel-secret-key-change-in-production-2024
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Email (dev default = print to console, no SMTP needed)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
